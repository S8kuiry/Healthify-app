<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to run ScreenActivityService as a foreground service (API 28+). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Required on API 34+ to declare the foreground service's type (dataSync fits a
         passive background-tracking service that isn't playing media, doing location,
         etc.). Must match the foregroundServiceType set on the <service> tag below. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Required on API 33+ (Android 13) to post any notification, including the mandatory
         foreground-service notification. Without this, startForeground() will fail at
         runtime on API 33+ unless the user has granted notification permission. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required to call UsageStatsManager for the future per-app usage breakdown. This is
         a "special access" permission - it cannot be granted via a runtime dialog like a
         normal permission. The user must manually enable it via the Settings screen opened
         by ScreenActivityModule.openUsageAccessSettings(). tools:ignore silences the lint
         warning that normally flags apps declaring a protected/signature permission. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Exact alarms for sleep window start/stop + reminders.
         USE_EXACT_ALARM (API 33+) is AUTO-GRANTED and non-revocable - the right choice for a
         reminder/alarm-clock style feature. This avoids the fresh-install trap of
         SCHEDULE_EXACT_ALARM, which on Android 13+ is NOT granted by default and has no
         in-app grant dialog, so after a reinstall canScheduleExactAlarms() returned false
         and the sleep module silently scheduled ZERO alarms (no reminder ever fired).
         SCHEDULE_EXACT_ALARM is kept as the fallback for API 31-32 where USE_EXACT_ALARM
         doesn't exist. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />

    <!-- Required to re-arm alarms after device reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Required for setExactAndAllowWhileIdle() on some devices. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application>
        <receiver
            android:name="expo.modules.screenactivity.SleepAlarmReceiver"
            android:exported="false" />
        <receiver
            android:name="expo.modules.screenactivity.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        <service
            android:name="expo.modules.screenactivity.ScreenActivityService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />
    </application>

</manifest>
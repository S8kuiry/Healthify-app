**/android/.gradle
**/android/.kotlin
**/.gradle

# iOS module files (skip if you only build Android APK)
modules/step-tracker/ios

# Local env / secrets
.env*.local
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Dev-only scripts not used during EAS build
scripts/reset-project.js
example